{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2021"],
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
