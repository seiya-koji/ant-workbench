{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "clean-sample-workspace",
      "type": "shell",
      "command": "node",
      "args": ["scripts/clean-sample-workspace.js"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "prepare-debug",
      "dependsOn": ["clean-sample-workspace", "npm: watch"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
